# VPS deployment template. Copy to .env on the server and replace every
# change-me value with a generated secret or environment-specific setting.

# Postgres
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me
POSTGRES_DB=n8n
POSTGRES_NON_ROOT_USER=n8n_dcss
POSTGRES_NON_ROOT_PASSWORD=change-me

# n8n auth and encryption
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=change-me-32-chars-min

# n8n runtime
N8N_IMAGE_TAG=2.7.4
N8N_RUNNERS_ENABLED=true
N8N_RUNNERS_MODE=external
N8N_RUNNERS_AUTH_TOKEN=change-me
N8N_NATIVE_PYTHON_RUNNER=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
GENERIC_TIMEZONE=UTC
TZ=UTC

# Public n8n URL behind Caddy
N8N_PORT=5678
N8N_HOST=n8n.example.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.example.com/
N8N_EDITOR_BASE_URL=https://n8n.example.com/

# Discord interactions proxy
DISCORD_PUBLIC_KEY=change-me
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/change-me
N8N_WEBHOOK_SHARED_SECRET=change-me
DISCORD_MAX_TIMESTAMP_AGE_SEC=300
N8N_PROXY_TIMEOUT_SEC=30
PYTHON_WORKER_LOG_LEVEL=INFO
AGENT_WORKER_ENABLED=true
AGENT_WORKER_POLL_SEC=3
AGENT_WORKER_BATCH_SIZE=2
AGENT_APPROVER_USER_IDS=
